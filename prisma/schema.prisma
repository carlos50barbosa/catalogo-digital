// Catálogo Digital — schema multi-tenant (banco único, isolamento por storeId).
// Provider mysql (MariaDB/MySQL). Toda tabela de loja carrega storeId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Plan {
  ESSENCIAL
  PROFISSIONAL
  PREMIUM
}

enum Role {
  OWNER
  STAFF
  SUPERADMIN // admin da plataforma — enxerga todas as lojas
}

enum StoreStatus {
  PENDING // self-service: cadastrado, aguardando 1º pagamento (não público)
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum BillingType {
  PIX
  BOLETO
  CREDIT_CARD
  UNDEFINED
}

enum Unit {
  UN
  KG
  L
  PCT
}

enum Fulfillment {
  DELIVERY_AND_PICKUP
  DELIVERY_ONLY
  PICKUP_ONLY
}

enum OrderType {
  DELIVERY
  PICKUP
}

enum OrderStatus {
  GENERATED // único status no MVP: pedido gerado (não confirmado)
}

enum FiadoAccountStatus {
  ACTIVE
  BLOCKED
}

enum FiadoEntryType {
  DEBIT // compra fiada — aumenta a dívida
  CREDIT // pagamento — abate a dívida
}

// ---------- Tenant ----------

/// Store é o tenant. Cada mercadinho é uma Store.
model Store {
  id             String      @id @default(cuid())
  slug           String      @unique // identifica a loja na vitrine pública /{slug}
  name           String
  logoUrl        String?
  whatsappNumber String // formato internacional, ex.: 5582999999999
  accentColor    String? // hex, ex.: #16a34a
  isActive       Boolean     @default(true) // legado: derivado de status (live = não SUSPENDED/CANCELED)
  status         StoreStatus @default(ACTIVE)
  published      Boolean     @default(true) // vitrine só vai ao ar quando publicada (self-service: false até concluir onboarding)
  plan           Plan        @default(ESSENCIAL)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  users         User[]
  settings      StoreSettings?
  categories    Category[]
  products      Product[]
  orders        Order[]
  customers     Customer[]
  subscription  Subscription?
  billingEvents BillingEvent[]
  nfeImports    NfeImport[]
  fiadoAccounts FiadoAccount[]
  fiadoEntries  FiadoEntry[]

  @@index([slug])
}

/// Dono/operador de uma loja. Pertence a exatamente uma Store.
model User {
  id                   String    @id @default(cuid())
  storeId              String
  email                String    @unique
  passwordHash         String
  name                 String
  role                 Role      @default(OWNER)
  emailVerified        DateTime? // null = não verificado
  emailVerifyToken     String?   @unique
  emailVerifyExpires   DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  passwordChangedAt    DateTime? // troca de senha invalida sessões JWT emitidas antes
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([email])
}

/// Configurações 1-1 da loja.
model StoreSettings {
  id                   String      @id @default(cuid())
  storeId              String      @unique
  address              String?
  deliveryFee          Decimal     @default(0) @db.Decimal(10, 2)
  minOrderValue        Decimal     @default(0) @db.Decimal(10, 2)
  pixKey               String?
  openingHours         Json? // { seg: {open,close}, ter: {...}, ... }
  deliveryZones        Json? // ["Centro", "Farol", ...]
  fulfillment          Fulfillment @default(DELIVERY_AND_PICKUP)
  orderMessageTemplate String?     @db.Text
  showOutOfStock       Boolean     @default(true) // mostrar produtos esgotados (true) ou ocultar (false)

  // ----- Fiado (caderneta digital) -----
  fiadoEnabled            Boolean @default(true) // liga/desliga o fiado nesta loja (além do gating por plano)
  fiadoDefaultTermDays    Int     @default(30) // prazo padrão do débito (dueDate = hoje + N dias)
  fiadoDefaultCreditLimit Decimal @default(0) @db.Decimal(10, 2) // limite padrão ao criar conta (0 = sem limite)
  fiadoReminderTemplate   String? @db.Text // texto da mensagem de cobrança (placeholders {nome} {loja} {saldo})

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ---------- Catálogo da loja ----------

model Category {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([storeId])
}

model Product {
  id            String   @id @default(cuid())
  storeId       String
  categoryId    String?
  catalogItemId String? // referência opcional à biblioteca compartilhada
  name          String
  description   String?  @db.Text
  price         Decimal  @db.Decimal(10, 2)
  cost          Decimal? @db.Decimal(10, 2) // custo de compra (ex.: vUnCom da NF-e); != preço de venda
  barcode       String? // GTIN/EAN — chave de match na importação por NF-e
  unit          Unit     @default(UN)
  imageUrl      String?
  isAvailable   Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]

  @@index([storeId, isAvailable])
  @@index([storeId, categoryId])
  @@index([storeId, barcode]) // match por código de barras (importação NF-e)
}

// ---------- Biblioteca compartilhada (GLOBAL, sem storeId) ----------

/// Catálogo mestre reaproveitável entre lojas (refrigerante, água, gás, arroz...).
/// Cadastra-se nome/foto uma vez; cada loja só define o próprio preço.
model CatalogItem {
  id                String   @id @default(cuid())
  name              String
  defaultImageUrl   String?
  barcode           String?  @unique
  brand             String?
  suggestedCategory String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  products Product[]

  @@index([name])
}

// ---------- Importação por NF-e (XML) ----------

/// Log/auditoria de importações por NF-e e guarda de deduplicação.
/// A chave de acesso (44 dígitos) é única por loja: impede reimportar a mesma nota.
model NfeImport {
  id           String   @id @default(cuid())
  storeId      String
  accessKey    String // chave de acesso da NF-e (44 dígitos)
  supplierName String? // emit/xNome
  supplierCnpj String? // emit/CNPJ
  itemCount    Int // quantos itens foram efetivamente importados
  createdAt    DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, accessKey]) // dedup: a mesma nota não entra duas vezes na loja
  @@index([storeId])
}

// ---------- Fiado (caderneta digital — livro-razão imutável) ----------

/// Conta corrente de fiado, 1-para-1 com Customer. `balance` é um CACHE
/// denormalizado (positivo = cliente deve), atualizado SEMPRE na mesma transação
/// do lançamento. A fonte da verdade são os FiadoEntry: balance é recalculável
/// por soma(DEBIT) − soma(CREDIT).
model FiadoAccount {
  id          String             @id @default(cuid())
  storeId     String
  customerId  String             @unique // 1 conta por cliente (satisfaz a relação 1-1)
  balance     Decimal            @default(0) @db.Decimal(10, 2)
  creditLimit Decimal            @default(0) @db.Decimal(10, 2) // 0 = sem limite
  status      FiadoAccountStatus @default(ACTIVE)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  store    Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  entries  FiadoEntry[]

  @@index([storeId])
}

/// Lançamento do livro-razão — IMUTÁVEL. Nunca é editado nem excluído.
/// Correção de erro = novo lançamento de estorno (reversesEntryId aponta o original).
/// `createdByUserId` é referência leve (auditoria de quem lançou) — sem FK para não
/// criar caminho duplo de cascade (Store→User e Store→FiadoEntry).
model FiadoEntry {
  id              String         @id @default(cuid())
  storeId         String
  fiadoAccountId  String
  customerId      String // denormalizado p/ consulta direta
  type            FiadoEntryType
  amount          Decimal        @db.Decimal(10, 2) // sempre positivo
  description     String?
  orderId         String? // vincula a um pedido de origem
  dueDate         DateTime? // vencimento (apenas p/ débitos)
  // @unique: um lançamento só pode ser estornado UMA vez. Como é nullable, o MySQL
  // permite vários NULLs e só barra reversesEntryId repetido — fecha o TOCTOU do
  // estorno concorrente (dois estornos do mesmo lançamento).
  reversesEntryId String?        @unique // se estorno, aponta o lançamento estornado
  createdByUserId String // auditoria (id do User da sessão)
  createdAt       DateTime       @default(now())

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fiadoAccount FiadoAccount @relation(fields: [fiadoAccountId], references: [id], onDelete: Cascade)
  order        Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  reverses     FiadoEntry?  @relation("FiadoReversal", fields: [reversesEntryId], references: [id], onDelete: SetNull)
  reversedBy   FiadoEntry?  @relation("FiadoReversal")

  @@index([storeId, fiadoAccountId, createdAt])
  @@index([storeId, customerId])
}

// ---------- Pedidos (order capture) ----------

/// Pedido GERADO (não confirmado). No MVP o pedido é a mensagem do WhatsApp;
/// aqui registramos uma cópia server-side, com valores recalculados no backend.
model Order {
  id            String      @id @default(cuid())
  storeId       String
  customerId    String?
  customerName  String
  customerPhone String
  fulfillment   OrderType
  address       String?
  paymentMethod String
  subtotal      Decimal     @db.Decimal(10, 2)
  deliveryFee   Decimal     @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(GENERATED)
  createdAt     DateTime    @default(now())

  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items        OrderItem[]
  fiadoEntries FiadoEntry[]

  @@index([storeId, createdAt])
  @@index([customerId])
}

/// Item do pedido com SNAPSHOT de nome/unidade/preço (histórico imune a alterações).
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String? // pode ficar null se o produto for excluído depois
  name        String // snapshot
  unit        Unit // snapshot
  quantity    Decimal @db.Decimal(10, 3) // decimal: suporta peso (KG)
  unitPrice   Decimal @db.Decimal(10, 2) // snapshot
  lineTotal   Decimal @db.Decimal(10, 2)
  isEstimated Boolean @default(false) // true para itens por KG (valor aproximado)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

// ---------- Base de clientes da loja ----------

model Customer {
  id          String    @id @default(cuid())
  storeId     String
  name        String
  phone       String
  address     String?
  // Opt-in explícito p/ receber contato/ofertas por WhatsApp (LGPD). O telefone
  // é coletado para EXECUTAR o pedido; usá-lo para marketing exige este consentimento.
  marketingConsent Boolean @default(false)
  createdAt   DateTime  @default(now())
  lastOrderAt DateTime?

  store        Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders       Order[]
  fiadoAccount FiadoAccount?

  @@unique([storeId, phone]) // reconhece cliente recorrente por loja
  @@index([storeId])
  @@index([phone])
}

// ---------- Assinatura / cobrança (Parte B) ----------

/// Assinatura da loja no gateway (Asaas). Espelha o estado da cobrança recorrente.
model Subscription {
  id                    String      @id @default(cuid())
  storeId               String      @unique
  gateway               String      @default("asaas")
  gatewayCustomerId     String?
  gatewaySubscriptionId String?
  cpfCnpj               String?     // documento do responsável (só dígitos); usado p/ sinalizar CPF repetido entre lojas
  plan                  Plan
  status                String      @default("PENDING") // espelha o status no gateway
  billingType           BillingType @default(UNDEFINED)
  value                 Decimal     @db.Decimal(10, 2)
  cycle                 String      @default("MONTHLY")
  nextDueDate           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  // O webhook resolve a loja por estes campos — hot path crítico de billing.
  @@index([gatewaySubscriptionId])
  @@index([gatewayCustomerId])
  @@index([cpfCnpj]) // lookup de CPF repetido entre lojas no /admin-plataforma
}

/// Log de auditoria/idempotência dos webhooks do gateway.
model BillingEvent {
  id             String   @id @default(cuid())
  storeId        String?
  gatewayEventId String   @unique // idempotência: não processa o mesmo evento 2x
  type           String
  payload        Json
  receivedAt     DateTime @default(now())

  store Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)

  @@index([storeId])
}

/// Trilha de auditoria das ações do SUPERADMIN sobre lojas (mexem em dinheiro/
/// acesso). Sem FK de propósito: o registro sobrevive à exclusão da loja/usuário.
model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String // id do SUPERADMIN que executou
  action        String // ex.: OVERRIDE_STATUS, CHANGE_PLAN, CREATE_SUBSCRIPTION, CANCEL_SUBSCRIPTION, DELETE_STORE
  targetStoreId String?
  detail        Json? // contexto (status novo, plano, valores...)
  createdAt     DateTime @default(now())

  @@index([targetStoreId])
  @@index([actorUserId])
}
