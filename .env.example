# =========================================================
# Catálogo Digital — variáveis de ambiente
# Copie para .env e ajuste os valores.
# =========================================================

# Banco de dados (MariaDB / MySQL)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="mysql://catalogo:senha_forte@localhost:3306/catalogo_digital"

# Auth.js / NextAuth
# Gere um segredo com:  openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-de-32-bytes"
# URL base usada pelo NextAuth (em produção: https://seu-dominio.com.br)
NEXTAUTH_URL="http://localhost:3000"

# URL pública da aplicação (usada em links da loja, metadata, Open Graph)
APP_URL="http://localhost:3000"

# Diretório onde os uploads (logos e fotos de produto) são gravados.
# EM PRODUÇÃO use um caminho ABSOLUTO e PERSISTENTE, fora do projeto — ex.:
#   UPLOAD_DIR="/var/www/catalogo/uploads"
# (e aponte o `alias` do `location /uploads/` do Nginx para o MESMO caminho).
# ATENÇÃO: um caminho relativo é resolvido na raiz do projeto. Como o `npm run build`
# regenera `.next/`, NÃO use uma pasta dentro de `.next`. O default abaixo serve só p/ dev.
UPLOAD_DIR="./uploads"

# Tamanho máximo de upload, em megabytes.
MAX_UPLOAD_MB="5"

# WhatsApp de vendas (CTAs de upgrade/regularização no painel "Meu plano")
SALES_WHATSAPP="5511915155349"

# ---------------------------------------------------------
# Self-service (cadastro público)
# ---------------------------------------------------------
SIGNUP_MODE="PAY_TO_ACTIVATE"     # PAY_TO_ACTIVATE | TRIAL
TRIAL_DAYS="7"                    # dias de teste no modo TRIAL
MIN_PRODUCTS_TO_PUBLISH="5"       # mínimo de produtos para publicar a loja

# E-mail transacional (verificação, boas-vindas). Sem EMAIL_HOST => loga no console (dev).
EMAIL_HOST=""
EMAIL_PORT="587"
EMAIL_SECURE="false"             # true para porta 465
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="Catálogo Digital <nao-responda@cataloggo.app.br>"

# ---------------------------------------------------------
# Asaas — cobrança recorrente (Parte B). Deixe vazio para
# operar de forma semi-manual (sem gateway). Use o sandbox em dev.
#
# ⚠️ IMPORTANTE: a chave do Asaas começa com "$" (ex.: $aact_...). ESCAPE o
# cifrão com barra invertida -> "\$aact_...". Sem o escape, o @next/env (usado
# pelo `next dev` e pelo servidor standalone em produção) roda dotenv-expand e
# trata "$aact_..." como variável inexistente, zerando a chave ("Pagamento
# indisponível no momento."). O lib/config.ts remove a barra de escape (no-op
# sobre valor cru), então "\$aact_..." funciona em dev e em produção.
# ---------------------------------------------------------
ASAAS_ENV="sandbox"               # sandbox | production
ASAAS_API_KEY="\$aact_..."        # chave da API do Asaas (escape o "$" inicial!)
ASAAS_WEBHOOK_TOKEN=""            # token configurado no webhook do Asaas (header asaas-access-token)
# Opcional — derivado de ASAAS_ENV se não informado:
# ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
