# =========================================================
# Catálogo Digital — variáveis de ambiente
# Copie para .env e ajuste os valores.
# =========================================================

# Banco de dados (MariaDB / MySQL)
# Formato: mysql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="mysql://catalogo:senha_forte@localhost:3306/catalogo_digital"

# Auth.js / NextAuth
# Gere um segredo com:  openssl rand -base64 32
NEXTAUTH_SECRET="troque-por-uma-string-aleatoria-de-32-bytes"
# URL base usada pelo NextAuth (em produção: https://seu-dominio.com.br)
NEXTAUTH_URL="http://localhost:3000"

# URL pública da aplicação (usada em links da loja, metadata, Open Graph)
APP_URL="http://localhost:3000"

# Diretório onde os uploads (logos e fotos de produto) são gravados.
# Em dev pode ser uma pasta local. Em produção numa VPS, algo fora do projeto,
# ex.: /var/www/catalogo/uploads  (servido pelo Nginx em /uploads/)
UPLOAD_DIR="./uploads"

# Tamanho máximo de upload, em megabytes.
MAX_UPLOAD_MB="5"

# WhatsApp de vendas (CTAs de upgrade/regularização no painel "Meu plano")
SALES_WHATSAPP="5582999999999"
# Taxa única de montagem (referência exibível, em R$)
SETUP_FEE="250"

# ---------------------------------------------------------
# Asaas — cobrança recorrente (Parte B). Deixe vazio para
# operar de forma semi-manual (sem gateway). Use o sandbox em dev.
# ---------------------------------------------------------
ASAAS_ENV="sandbox"               # sandbox | production
ASAAS_API_KEY=""                  # chave da API do Asaas
ASAAS_WEBHOOK_TOKEN=""            # token configurado no webhook do Asaas (header asaas-access-token)
# Opcional — derivado de ASAAS_ENV se não informado:
# ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
