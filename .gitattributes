# Normaliza finais de linha para LF no repositório.
# Essencial para que deploy.sh e outros scripts rodem na VPS Linux
# (CRLF quebra o shebang: "bad interpreter: bash\r").
* text=auto eol=lf

# Scripts shell SEMPRE com LF.
*.sh text eol=lf

# Arquivos binários: não tocar.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
